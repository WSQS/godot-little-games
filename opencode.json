{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ns-deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ns-deepseek",
      "options": {
        "baseURL": "https://ai.jiachengyun.com/v1",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoningEffort": "max"
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        }
      }
    }
  },
  "model": "ns-deepseek/deepseek-v4-pro",
  "small_model": "ns-deepseek/deepseek-v4-flash"
}